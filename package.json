{
  "name": "@logplex/player-react",
  "version": "0.1.0",
  "description": "Logplex video player for React — Vidstack-based, HLS/MP4, fully skinned (RTL/LTR), with built-in Logplex analytics, resume, ads, gestures and WebView-safe fullscreen.",
  "type": "module",
  "license": "UNLICENSED",
  "author": "Logplex",
  "homepage": "https://gitlab.noyanet.ir/shad-core/logplex/player-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.noyanet.ir/shad-core/logplex/player-react.git"
  },
  "bugs": {
    "url": "https://gitlab.noyanet.ir/shad-core/logplex/player-react/-/issues"
  },
  "keywords": [
    "react",
    "video",
    "player",
    "hls",
    "vidstack",
    "rtl",
    "analytics",
    "resume",
    "continue-watching",
    "logplex"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "docs:build": "vite build --config vite.docs.config.ts",
    "docs:preview": "vite preview --config vite.docs.config.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@vidstack/react": "^1.12.13",
    "hls.js": "^1.5.18",
    "media-icons": "^1.1.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0"
  }
}
